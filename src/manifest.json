{
  "manifest_version": 3,
  "name": "Site Blocker",
  "version": "0.1.0",
  "description": "Soft voluntary site blocker for habit change.",
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Site Blocker",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/reminder.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked/blocked.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
